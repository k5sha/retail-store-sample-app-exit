{
  "*.{js,jsx,ts,tsx,json,md,yaml,yml}": "prettier --write",
  "*.java": "prettier --write",
  "*.xml": "prettier --write",
  "*.go": "gofmt -w",
  "*.tf": ["terraform fmt", "tflint"],
  "samples/data/**": "yarn nx run-many -t update-samples --projects=tag:sample --parallel=1",
  "samples/images/**": "yarn nx run-many -t update-samples --projects=tag:sample --parallel=1"
}
